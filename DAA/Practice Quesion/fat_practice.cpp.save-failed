/*
#include <bits/stdc++.h>
using namespace std;

int cross(vector<int>&arr,int s,int e)
{
    int mid=(s+e)/2;

    int lem=INT_MIN, ler=0;
    int rim=INT_MIN, rir=0;

    int fg1=0, fg2=0;

    // left side
    for(int i=mid;i>=s;i--)
    {
        ler+=arr[i];

        if(arr[i]==2)
            fg1=1;

        lem=max(lem,ler);
    }

    // right side
    for(int i=mid+1;i<=e;i++)
    {
        rir+=arr[i];

        if(arr[i]==2)
            fg2=1;

        rim=max(rim,rir);
    }

    if(fg1 || fg2)
        return lem+rim;

    return INT_MIN;
}

int sub(vector<int>&arr,int s,int e)
{
    if(s==e)
    {
        if(arr[s]==2)
            return arr[s];
        return INT_MIN;
    }

    int mid=(s+e)/2;

    int lm=sub(arr,s,mid);
    int rm=sub(arr,mid+1,e);
    int cm=cross(arr,s,e);

    return max({lm,rm,cm});
}

int main()
{
    int n;
    cin>>n;

    vector<int> arr(n);

    for(int i=0;i<n;i++)
        cin>>arr[i];

    int ans=sub(arr,0,n-1);

    if(ans==INT_MIN)
        cout<<0;
    else
        cout<<ans;
}
