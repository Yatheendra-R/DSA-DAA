        struct node *l=pq.top();
        pq.pop();
        struct node *r=pq.top();
        pq.pop();
        struct node *newnode=new node('$',l->f+r->f);
        newnode->left=l;
        newnode->right=r;
        pq.push(newnode);
    }
    ptcode(pq.top(),"");

    return 0;
}*/
